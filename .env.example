# GPU Cloud Platform Environment Configuration

# Database Configuration
DATABASE_URL=mysql+pymysql://gpu_cloud:CHANGE_ME_DB_PASSWORD@localhost:3306/gpu_cloud_platform
DB_USER=gpu_cloud
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gpu_cloud_platform

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# libvirt Configuration
LIBVIRT_URI=qemu:///system

# Open vSwitch Configuration
OVS_BRIDGE=br-tenant

# Flask Configuration
SECRET_KEY=CHANGE_ME_FLASK_SECRET_KEY_VERY_LONG_RANDOM_STRING
FLASK_DEBUG=false
PORT=5000

# Security Configuration
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY_VERY_LONG_RANDOM_STRING
JWT_EXPIRATION_HOURS=24

# Performance Configuration
WORKER_COUNT=4
RECONCILIATION_INTERVAL=60
METRICS_COLLECTION_INTERVAL=30

# Logging Configuration
LOG_LEVEL=INFO
SQL_DEBUG=false

# Host Configuration
HOST_CONFIG_PATH=/app/config/host-config.yaml

# WebSocket Configuration
WEBSOCKET_PORT=8765
WEBSOCKET_PING_INTERVAL=20
WEBSOCKET_PING_TIMEOUT=10

# Rate Limiting
API_RATE_LIMIT=100
WEBSOCKET_RATE_LIMIT=50

# Resource Limits
MAX_VMS_PER_TENANT=10
MAX_VCPUS_PER_TENANT=40
MAX_MEMORY_GB_PER_TENANT=128
MAX_DISK_GB_PER_TENANT=1000
MAX_GPUS_PER_TENANT=2
